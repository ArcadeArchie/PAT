{
  "build": {
    "beforeDevCommand": "pnpm start --port 1420",
    "beforeBuildCommand": "pnpm build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist/pat-launcher",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "pat-launcher",
    "version": "0.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "de.nstrassburger.dev",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "center": true,
        "fullscreen": false,
        "resizable": true,
        "title": "pat-launcher",
        "width": 800,
        "height": 600,
        "visible": false
      },
      {
        "center": true,
        "height": 600,
        "width": 400,
        "decorations": false,
        "url": "splash.html",
        "label": "splashscreen"
      }
    ]
  }
}